# 可选：配置后启用 OpenAI Embedding + LLM 真实调用
# 不配置时使用本地词袋向量和模板 fallback，不影响基本功能
OPENAI_API_KEY=your_openai_api_key_here

# 以下为可选覆盖项
# OPENAI_MODEL=gpt-4o-mini          # 对话模型
# EMBEDDING_MODEL=text-embedding-3-small  # 向量化模型
# LLM_TIMEOUT_MS=5000               # LLM 超时（毫秒），超时后降级
# PORT=3001                         # 后端端口
